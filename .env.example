# =============================================================================
# MediSense — Environment Variables
# -----------------------------------------------------------------------------
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in YOUR values in the new .env file.
#   3. NEVER commit the .env file — it is listed in .gitignore.
#   4. NEVER put real credentials in this file (.env.example).
# =============================================================================

# --- Server ---
PORT=3000

# --- Frontend API base URL ---
VITE_API_URL=http://localhost:3000

# --- MongoDB (required for full-stack persistence) — see MONGODB_SETUP.md ---
# Local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/medisense

# MongoDB Atlas (cloud) — replace with your real connection string in .env only:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/medisense?retryWrites=true&w=majority
# WARNING: Never put a real Atlas URI with credentials in this file.

# --- EmailJS (OTP email delivery) — see EMAILJS_SETUP.md ---
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# --- Optional: OpenAI (enhanced report analysis) ---
# When set, enables GPT-based insights for PDF/image reports.
# Leave empty to use built-in analysis pipeline.
VITE_OPENAI_API_KEY=

# --- Session / JWT ---
# Used to sign auth tokens. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
