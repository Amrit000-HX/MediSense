# =============================================================================
# MediSense — Environment Variables
# Copy this file to .env and fill in values. Never commit .env to git.
# =============================================================================

# --- Required for full-stack local development ---
VITE_API_URL=http://localhost:3000

# --- Optional: Enhanced report analysis (OpenAI) ---
# When set, enables GPT-based insights for PDF/image reports.
# Leave empty to use built-in analysis pipeline.
VITE_OPENAI_API_KEY=

# --- EmailJS (OTP login) — see EMAILJS_SETUP.md ---
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# --- MongoDB (optional persistence) — see MONGODB_SETUP.md ---
MONGODB_URI=mongodb://127.0.0.1:27017/medisense

# --- Server ---
PORT=3000
